<!-- Created with Jaspersoft Studio version 7.0.2.final using JasperReports Library version 6.20.6  -->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Backward_Trace" pageWidth="842" pageHeight="595" orientation="Landscape" whenNoDataType="AllSectionsNoDetail" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="a2b2c3d4-e5f6-7890-abcd-ef1234567891">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="CalHelp Data Adapter"/>
	<property name="com.jaspersoft.studio.unit." value="pixel"/>
	<style name="UnicodeDefault" isDefault="true" fontName="DejaVu Sans" pdfFontName="DejaVu Sans" pdfEncoding="Identity-H" isPdfEmbedded="false"/>
	<parameter name="instrumentId" class="java.lang.String">
		<parameterDescription><![CDATA[MTAG des DUT fuer die Rueckfuehrungskette.]]></parameterDescription>
	</parameter>
	<parameter name="maxDepth" class="java.lang.Integer">
		<parameterDescription><![CDATA[Maximale Rekursionstiefe (Standard: 10).]]></parameterDescription>
		<defaultValueExpression><![CDATA[10]]></defaultValueExpression>
	</parameter>
	<parameter name="PrefixTable" class="java.lang.String">
		<parameterDescription><![CDATA[Optionales Tabellenpräfix fuer Mandantentrennung.]]></parameterDescription>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="Sprache" class="java.lang.String">
		<parameterDescription><![CDATA[Steuert die Spaltentitel (Deutsch/Englisch).]]></parameterDescription>
		<defaultValueExpression><![CDATA["Deutsch"]]></defaultValueExpression>
	</parameter>
	<queryString language="SQL">
		<![CDATA[WITH RECURSIVE trace AS (
    SELECT
        1 AS depth,
        s.C2430 AS instrument_id,
        s.CTAG AS calibration_id,
        COALESCE(i.I4201, "") AS asset_number,
        COALESCE(i.I4202, "") AS serial_number,
        COALESCE(i.I4203, "") AS description,
        COALESCE(i.I4204, "") AS type_code,
        COALESCE(i.I4206, "") AS manufacturer,
        COALESCE(i.I4207, "") AS model,
        c_std.C2301 AS calibration_date,
        c_std.C2303 AS next_calibration_date,
        COALESCE(c_std.C2308, "") AS certificate_number,
        COALESCE(c_std.C2323, "") AS cal_result,
        COALESCE(c_std.C2364, "") AS cal_mark,
        COALESCE(c_std.status, "") AS cal_status,
        CAST(s.C2430 AS CHAR(10000)) AS visited_path
    FROM $P!{PrefixTable}calibration c_dut
    JOIN $P!{PrefixTable}standards s
        ON s.CTAG = c_dut.CTAG
    JOIN $P!{PrefixTable}inventory i
        ON i.MTAG = s.C2430
    LEFT JOIN $P!{PrefixTable}calibration c_std
        ON c_std.MTAG = s.C2430 AND c_std.C2339 = 1
    WHERE c_dut.MTAG = $P{instrumentId}
      AND c_dut.C2339 = 1

    UNION ALL

    SELECT
        t.depth + 1,
        s2.C2430,
        s2.CTAG,
        COALESCE(i2.I4201, ""),
        COALESCE(i2.I4202, ""),
        COALESCE(i2.I4203, ""),
        COALESCE(i2.I4204, ""),
        COALESCE(i2.I4206, ""),
        COALESCE(i2.I4207, ""),
        c_std2.C2301,
        c_std2.C2303,
        COALESCE(c_std2.C2308, ""),
        COALESCE(c_std2.C2323, ""),
        COALESCE(c_std2.C2364, ""),
        COALESCE(c_std2.status, ""),
        CONCAT(t.visited_path, ',', s2.C2430)
    FROM trace t
    JOIN $P!{PrefixTable}calibration c_parent
        ON c_parent.MTAG = t.instrument_id AND c_parent.C2339 = 1
    JOIN $P!{PrefixTable}standards s2
        ON s2.CTAG = c_parent.CTAG
    JOIN $P!{PrefixTable}inventory i2
        ON i2.MTAG = s2.C2430
    LEFT JOIN $P!{PrefixTable}calibration c_std2
        ON c_std2.MTAG = s2.C2430 AND c_std2.C2339 = 1
    WHERE t.depth < $P{maxDepth}
      AND FIND_IN_SET(s2.C2430, t.visited_path) = 0
)
SELECT
    depth,
    instrument_id,
    asset_number,
    serial_number,
    description,
    type_code,
    manufacturer,
    model,
    calibration_date,
    next_calibration_date,
    certificate_number,
    cal_result,
    cal_mark,
    cal_status
FROM trace
ORDER BY depth ASC, description ASC]]>
	</queryString>
