	</variable>
	<variable name="col_result" class="java.lang.String">
		<variableExpression><![CDATA[$P{Sprache}.equals("Deutsch") ? "Ergebnis" : "Result"]]></variableExpression>
	</variable>
	<variable name="col_certificate" class="java.lang.String">
		<variableExpression><![CDATA[$P{Sprache}.equals("Deutsch") ? "Zertifikat-Nr." : "Certificate No."]]></variableExpression>
	</variable>
	<variable name="col_duedate" class="java.lang.String">
		<variableExpression><![CDATA[$P{Sprache}.equals("Deutsch") ? "Fälligkeitsdatum" : "Due Date"]]></variableExpression>
	</variable>
	<variable name="col_calmark" class="java.lang.String">
		<variableExpression><![CDATA[$P{Sprache}.equals("Deutsch") ? "Kal.-Marke" : "Cal. Mark"]]></variableExpression>
	</variable>
