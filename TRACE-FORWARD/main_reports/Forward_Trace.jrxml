<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Forward_Trace" pageWidth="842" pageHeight="595" orientation="Landscape" whenNoDataType="AllSectionsNoDetail" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="a1000001-0001-0001-0001-000000000001">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="CalHelp Data Adapter"/>
	<property name="com.jaspersoft.studio.unit." value="pixel"/>
	<style name="UnicodeDefault" isDefault="true" fontName="DejaVu Sans" pdfFontName="DejaVu Sans" pdfEncoding="Identity-H" isPdfEmbedded="false"/>
	<parameter name="P_MTAG" class="java.lang.String">
		<parameterDescription><![CDATA[MTAG des Instruments.]]></parameterDescription>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="maxDepth" class="java.lang.String">
		<parameterDescription><![CDATA[Maximale Rekursionstiefe 1-5 (Standard: 5).]]></parameterDescription>
		<defaultValueExpression><![CDATA["5"]]></defaultValueExpression>
	</parameter>
	<parameter name="PrefixTable" class="java.lang.String">
		<parameterDescription><![CDATA[Optionales Tabellenpräfix fuer Mandantentrennung.]]></parameterDescription>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="Sprache" class="java.lang.String">
		<parameterDescription><![CDATA[Steuert die Spaltentitel (Deutsch/Englisch).]]></parameterDescription>
		<defaultValueExpression><![CDATA["Deutsch"]]></defaultValueExpression>
	</parameter>
	<queryString language="SQL">
		<![CDATA[SELECT depth, instrument_id, asset_number, serial_number, description,
       type_code, manufacturer, model, calibration_date, next_calibration_date,
       certificate_number, cal_result, cal_mark, cal_status
FROM (
  /* ---- Stufe 0: Das analysierte Normal selbst ---- */
  SELECT 0 AS depth,
    i0.MTAG AS instrument_id,
    COALESCE(i0.I4201, '') AS asset_number,
    COALESCE(i0.I4202, '') AS serial_number,
    COALESCE(i0.I4203, '') AS description,
    COALESCE(i0.I4204, '') AS type_code,
    COALESCE(i0.I4206, '') AS manufacturer,
    COALESCE(i0.I4207, '') AS model,
    c0.C2301 AS calibration_date,
    c0.C2303 AS next_calibration_date,
    COALESCE(c0.C2308, '') AS certificate_number,
    COALESCE(c0.C2323, '') AS cal_result,
    COALESCE(c0.C2364, '') AS cal_mark,
    COALESCE(c0.status, '') AS cal_status
  FROM $P!{PrefixTable}inventory i0
  LEFT JOIN $P!{PrefixTable}calibration c0 ON c0.MTAG = i0.MTAG AND c0.C2339 = 1
  WHERE i0.MTAG = '$P!{P_MTAG}'

  UNION ALL

  /* ---- Stufe 1 ---- */
  SELECT 1,
    s1.MTAG,
    COALESCE(i1.I4201, ''), COALESCE(i1.I4202, ''),
    COALESCE(i1.I4203, ''), COALESCE(i1.I4204, ''),
    COALESCE(i1.I4206, ''), COALESCE(i1.I4207, ''),
    c1.C2301, c1.C2303,
    COALESCE(c1.C2308, ''), COALESCE(c1.C2323, ''),
    COALESCE(c1.C2364, ''), COALESCE(c1.status, '')
  FROM $P!{PrefixTable}standards s1
  JOIN $P!{PrefixTable}calibration c1 ON c1.CTAG = s1.CTAG AND c1.C2339 = 1
  JOIN $P!{PrefixTable}inventory i1   ON i1.MTAG = s1.MTAG
  WHERE s1.C2430 = '$P!{P_MTAG}'

  UNION ALL

  /* ---- Stufe 2 ---- */
  SELECT 2,
    s2.MTAG,
    COALESCE(i2.I4201, ''), COALESCE(i2.I4202, ''),
    COALESCE(i2.I4203, ''), COALESCE(i2.I4204, ''),
    COALESCE(i2.I4206, ''), COALESCE(i2.I4207, ''),
    c2.C2301, c2.C2303,
    COALESCE(c2.C2308, ''), COALESCE(c2.C2323, ''),
    COALESCE(c2.C2364, ''), COALESCE(c2.status, '')
  FROM $P!{PrefixTable}standards s1
  JOIN $P!{PrefixTable}calibration c1 ON c1.CTAG = s1.CTAG AND c1.C2339 = 1
  JOIN $P!{PrefixTable}standards s2   ON s2.C2430 = s1.MTAG
  JOIN $P!{PrefixTable}calibration c2 ON c2.CTAG = s2.CTAG AND c2.C2339 = 1
  JOIN $P!{PrefixTable}inventory i2   ON i2.MTAG = s2.MTAG
  WHERE s1.C2430 = '$P!{P_MTAG}'
    AND s2.MTAG != '$P!{P_MTAG}'

  UNION ALL

  /* ---- Stufe 3 ---- */
  SELECT 3,
    s3.MTAG,
    COALESCE(i3.I4201, ''), COALESCE(i3.I4202, ''),
    COALESCE(i3.I4203, ''), COALESCE(i3.I4204, ''),
    COALESCE(i3.I4206, ''), COALESCE(i3.I4207, ''),
    c3.C2301, c3.C2303,
    COALESCE(c3.C2308, ''), COALESCE(c3.C2323, ''),
    COALESCE(c3.C2364, ''), COALESCE(c3.status, '')
  FROM $P!{PrefixTable}standards s1
  JOIN $P!{PrefixTable}calibration c1 ON c1.CTAG = s1.CTAG AND c1.C2339 = 1
  JOIN $P!{PrefixTable}standards s2   ON s2.C2430 = s1.MTAG
  JOIN $P!{PrefixTable}calibration c2 ON c2.CTAG = s2.CTAG AND c2.C2339 = 1
  JOIN $P!{PrefixTable}standards s3   ON s3.C2430 = s2.MTAG
  JOIN $P!{PrefixTable}calibration c3 ON c3.CTAG = s3.CTAG AND c3.C2339 = 1
  JOIN $P!{PrefixTable}inventory i3   ON i3.MTAG = s3.MTAG
  WHERE s1.C2430 = '$P!{P_MTAG}'
    AND s2.MTAG != '$P!{P_MTAG}'
    AND s3.MTAG != '$P!{P_MTAG}' AND s3.MTAG != s1.MTAG

  UNION ALL

  /* ---- Stufe 4 ---- */
  SELECT 4,
    s4.MTAG,
    COALESCE(i4.I4201, ''), COALESCE(i4.I4202, ''),
    COALESCE(i4.I4203, ''), COALESCE(i4.I4204, ''),
    COALESCE(i4.I4206, ''), COALESCE(i4.I4207, ''),
    c4.C2301, c4.C2303,
    COALESCE(c4.C2308, ''), COALESCE(c4.C2323, ''),
    COALESCE(c4.C2364, ''), COALESCE(c4.status, '')
  FROM $P!{PrefixTable}standards s1
  JOIN $P!{PrefixTable}calibration c1 ON c1.CTAG = s1.CTAG AND c1.C2339 = 1
  JOIN $P!{PrefixTable}standards s2   ON s2.C2430 = s1.MTAG
  JOIN $P!{PrefixTable}calibration c2 ON c2.CTAG = s2.CTAG AND c2.C2339 = 1
  JOIN $P!{PrefixTable}standards s3   ON s3.C2430 = s2.MTAG
  JOIN $P!{PrefixTable}calibration c3 ON c3.CTAG = s3.CTAG AND c3.C2339 = 1
  JOIN $P!{PrefixTable}standards s4   ON s4.C2430 = s3.MTAG
  JOIN $P!{PrefixTable}calibration c4 ON c4.CTAG = s4.CTAG AND c4.C2339 = 1
  JOIN $P!{PrefixTable}inventory i4   ON i4.MTAG = s4.MTAG
  WHERE s1.C2430 = '$P!{P_MTAG}'
    AND s2.MTAG != '$P!{P_MTAG}'
    AND s3.MTAG != '$P!{P_MTAG}' AND s3.MTAG != s1.MTAG
    AND s4.MTAG != '$P!{P_MTAG}' AND s4.MTAG != s1.MTAG AND s4.MTAG != s2.MTAG

  UNION ALL

  /* ---- Stufe 5 ---- */
  SELECT 5,
    s5.MTAG,
    COALESCE(i5.I4201, ''), COALESCE(i5.I4202, ''),
    COALESCE(i5.I4203, ''), COALESCE(i5.I4204, ''),
    COALESCE(i5.I4206, ''), COALESCE(i5.I4207, ''),
    c5.C2301, c5.C2303,
    COALESCE(c5.C2308, ''), COALESCE(c5.C2323, ''),
    COALESCE(c5.C2364, ''), COALESCE(c5.status, '')
  FROM $P!{PrefixTable}standards s1
  JOIN $P!{PrefixTable}calibration c1 ON c1.CTAG = s1.CTAG AND c1.C2339 = 1
  JOIN $P!{PrefixTable}standards s2   ON s2.C2430 = s1.MTAG
  JOIN $P!{PrefixTable}calibration c2 ON c2.CTAG = s2.CTAG AND c2.C2339 = 1
  JOIN $P!{PrefixTable}standards s3   ON s3.C2430 = s2.MTAG
  JOIN $P!{PrefixTable}calibration c3 ON c3.CTAG = s3.CTAG AND c3.C2339 = 1
  JOIN $P!{PrefixTable}standards s4   ON s4.C2430 = s3.MTAG
  JOIN $P!{PrefixTable}calibration c4 ON c4.CTAG = s4.CTAG AND c4.C2339 = 1
  JOIN $P!{PrefixTable}standards s5   ON s5.C2430 = s4.MTAG
  JOIN $P!{PrefixTable}calibration c5 ON c5.CTAG = s5.CTAG AND c5.C2339 = 1
  JOIN $P!{PrefixTable}inventory i5   ON i5.MTAG = s5.MTAG
  WHERE s1.C2430 = '$P!{P_MTAG}'
    AND s2.MTAG != '$P!{P_MTAG}'
    AND s3.MTAG != '$P!{P_MTAG}' AND s3.MTAG != s1.MTAG
    AND s4.MTAG != '$P!{P_MTAG}' AND s4.MTAG != s1.MTAG AND s4.MTAG != s2.MTAG
    AND s5.MTAG != '$P!{P_MTAG}' AND s5.MTAG != s1.MTAG AND s5.MTAG != s2.MTAG AND s5.MTAG != s3.MTAG
) AS trace
WHERE depth <= IFNULL(NULLIF('$P!{maxDepth}',''),5)
ORDER BY depth ASC, description ASC]]>
	</queryString>
	<field name="depth" class="java.lang.Integer"/>
	<field name="instrument_id" class="java.lang.String"/>
	<field name="asset_number" class="java.lang.String"/>
	<field name="serial_number" class="java.lang.String"/>
	<field name="description" class="java.lang.String"/>
	<field name="type_code" class="java.lang.String"/>
	<field name="manufacturer" class="java.lang.String"/>
	<field name="model" class="java.lang.String"/>
	<field name="calibration_date" class="java.sql.Date"/>
	<field name="next_calibration_date" class="java.sql.Date"/>
	<field name="certificate_number" class="java.lang.String"/>
	<field name="cal_result" class="java.lang.String"/>
	<field name="cal_mark" class="java.lang.String"/>
	<field name="cal_status" class="java.lang.String"/>
	<variable name="col_depth" class="java.lang.String">
		<variableExpression><![CDATA[$P{Sprache}.equals("Deutsch") ? "Stufe" : "Depth"]]></variableExpression>
	</variable>
	<variable name="col_asset" class="java.lang.String">
		<variableExpression><![CDATA[$P{Sprache}.equals("Deutsch") ? "Inv.-Nr." : "Asset No."]]></variableExpression>
	</variable>
	<variable name="col_serial" class="java.lang.String">
		<variableExpression><![CDATA[$P{Sprache}.equals("Deutsch") ? "Seriennr." : "Serial No."]]></variableExpression>
	</variable>
